      <column caption='Growth Rate' datatype='real' name='[Calculation_0616053221064708]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='(([Calculation_1487140905832453])-([Calculation_1487140904759299])) / [Calculation_1487140904759299]*100' />
      </column>
