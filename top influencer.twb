        <calculation class='tableau' formula='Float(REPLACE(REPLACE([followers],&quot;m&quot;,&quot;&quot;),&quot;b&quot;,&quot;&quot;)) *&#13;&#10;IF CONTAINS([followers],&quot;m&quot;) THEN 1000000 ELSE 1 END' />
