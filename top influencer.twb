        <calculation class='tableau' formula='FLOAT(REPLACE([posts],&quot;k&quot;,&quot;&quot;)) *&#13;&#10;IF CONTAINS([posts],&quot;k&quot;) THEN 1000 ELSE 1 END' />
      </column>
      <column caption='Avg_likes' datatype='real' name='[Calculation_1487140904759299]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='FLOAT(REPLACE(REPLACE([avg_likes],&quot;m&quot;,&quot;&quot;),&quot;k&quot;,&quot;&quot;)) *&#13;&#10;IF CONTAINS([avg_likes],&quot;m&quot;) THEN 1000000 ELSEIF &#13;&#10;CONTAINS([avg_likes],&quot;k&quot;)THEN 1000 ELSE 1 END' />
      </column>
      <column caption='New_post_Avg_Like' datatype='real' name='[Calculation_1487140905832453]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='FLOAT(REPLACE(REPLACE([new_post_avg_like],&quot;m&quot;,&quot;&quot;),&quot;k&quot;,&quot;&quot;)) *&#13;&#10;IF CONTAINS([new_post_avg_like],&quot;m&quot;) THEN 1000000 ELSEIF &#13;&#10;CONTAINS([new_post_avg_like],&quot;k&quot;)THEN 1000 ELSE 1 END' />
      </column>
      <column caption='Total_likes' datatype='real' name='[Calculation_1487140907610118]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='FLOAT(REPLACE(REPLACE([total_likes],&quot;m&quot;,&quot;&quot;),&quot;b&quot;,&quot;&quot;)) *&#13;&#10;IF CONTAINS([total_likes],&quot;m&quot;) THEN 1000000 ELSEIF &#13;&#10;CONTAINS([total_likes],&quot;b&quot;)THEN 1000000000 ELSE 1 END' />
